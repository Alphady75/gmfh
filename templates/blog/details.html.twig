{% extends 'base.html.twig' %}

{% block title %}{{ article }}{% endblock %}

{% block body %}
<!-- INNER PAGE BANNER -->
<div class="wt-bnr-inr overlay-wraper bg-center" style="background-image:url({{ asset('themes/base/images/banner/1.jpg') }});">
  <div class="overlay-main site-bg-white opacity-01"></div>
  <div class="container">
    <div class="wt-bnr-inr-entry">
      <div class="banner-title-outer">
        <div class="banner-title-name">
          <h2 class="wt-title">{{ article.name|u.truncate(20, '...') }}</h2>
        </div>
      </div>
      <!-- BREADCRUMB ROW -->
      <div>
        <ul class="wt-breadcrumb breadcrumb-style-2">
          <li><a href="{{ path('accueil') }}">Accueil</a></li>
          <li>{{ article.name|u.truncate(20, '...') }}</li>
        </ul>
      </div>
      <!-- BREADCRUMB ROW END -->
    </div>
  </div>
</div>
<!-- INNER PAGE BANNER END -->

<!-- OUR BLOG START -->
<div class="section-full  p-t120 p-b90 bg-white">
  <div class="container">

    <!-- BLOG SECTION START -->
    <div class="section-content">
      <div class="row d-flex justify-content-center">

        <div class="col-lg-8 col-md-12">
          <!-- BLOG START -->
          <div class="blog-post-single-outer">
            <div class="blog-post-single bg-white">

              <div class="wt-post-info">

                <div class="wt-post-media m-b30">
                  <img src="images/blog/blog-single/1.jpg" alt="">
                </div>

                <div class="wt-post-title ">
                  <div class="wt-post-meta-list">
                    <div class="wt-list-content post-date">April 05, 2023</div>
                    <div class="wt-list-content post-author">Par {{ article.user }}</div>
                  </div>
                  <h3 class="post-title">{{ article }}</h3>

                </div>

                <div class="wt-post-discription">

                  {{ article.description|raw }}

                </div>


                <div class="twm-posts-author">
                  <div class="twm-post-author-pic">
                    <img src="images/blog/post-author.jpg" alt="#">
                  </div>
                  <div class="twm-post-author-content">
                    <span>435 Posts Since 2018</span>
                    <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor
                      incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam,
                    </p>
                    <strong>Rosalina William</strong>
                  </div>
                </div>



              </div>



            </div>

            <div class="post-area-tags-wrap">
              <div class="post-social-icons-wrap">
                <h4 class="mb-4">Share</h4>
                <ul class="post-social-icons">
                  <li><a href="javascript:void(0);" class="fab fa-facebook-f"></a></li>
                  <li><a href="javascript:void(0);" class="fab fa-twitter"></a></li>
                  <li><a href="javascript:void(0);" class="fab fa-linkedin-in"></a></li>
                  <li><a href="javascript:void(0);" class="fab fa-google"></a></li>
                </ul>
              </div>
            </div>

            {% include "blog/composants/_comments.html.twig" %}

          </div>
        </div>

        <div class="col-lg-4 col-md-12 rightSidebar">

          <div class="side-bar">

            <div class="widget all_services_list">
              <h4 class="section-head-small mb-4">Categories</h4>
              <div class="all_services m-b30">
                <ul>
                  {% for categorie in articlecategories() %}
                  <li><a href="{{ path('blog_categories', {slug: categorie.slug}) }}">{{ categorie.name|u.truncate(20, '...') }}</a> <span class="badge">{{ categorie.articles|length }}</span></li>
                  {% endfor %}
                </ul>
              </div>
            </div>

            <div class="widget recent-posts-entry">
              <h4 class="section-head-small mb-4">Articles récents</h4>
              <div class="section-content">
                <div class="widget-post-bx">

                  {% for similar in similars %}
                  <div class="widget-post clearfix">
                    <div class="wt-post-media">
                      <img src="{{ asset('themes/base/images/blog/recent-blog/pic1.jpg') }}" alt="">
                    </div>
                    <div class="wt-post-info">
                      <div class="wt-post-header">
                        <span class="post-date">{{ similar.created|date('D m Y') }}</span>
                        <span class="post-title">
                          <a href="{{ path('blog_details', {slug: similar.slug}) }}">{{ similar.name|u.truncate(20, '...') }}</a>
                        </span>
                      </div>
                    </div>
                  </div>
                  {% endfor %}

                </div>
              </div>
            </div>



            <div class="widget tw-sidebar-tags-wrap">
              <h4 class="section-head-small mb-4">Mots clés</h4>

              <div class="tagcloud">
                {% for tag in tags() %}
                <a href="{{ path('blog_tags', {slug: tag.slug}) }}">{{ tag }}</a>
                {% endfor %}
              </div>
            </div>


          </div>


        </div>

      </div>

    </div>

  </div>

</div>
<!-- OUR BLOG END -->
{% endblock %}