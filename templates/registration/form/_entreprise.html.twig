{{ form_start(form, {attr: {class: 'p-3'}}) }}

<div class="text-center">
	<label for="profil_entreprise_logoFile_file" class="avatar-img">
		<img src="{% if app.user.logo %}{{ vich_uploader_asset(app.user, 'logoFile' ) | imagine_filter('largeavatar') }}{% else %}{{ asset('img/banner.png') | imagine_filter('largeavatar') }}{% endif %}"
			class="rounded-circle logo-img img-fluid img-thumbnail" alt="Avatar de compte">
			<label class="btn" for="profil_entreprise_logoFile_file" ><i class="text-blue fa fa-camera"></i></label>
	</label>
	<div class="hidden-file">{{ form_widget(form.logoFile) }}</div>
	{{ form_errors(form.logoFile) }}
	<p class="text-center"><strong>Logo</strong></p>
</div>

<div class="row">
	<div class="col-sm-12">{{ form_row(form.societe) }}</div>
	<div class="col-sm-6">{{ form_row(form.niu) }}</div>
	<div class="col-sm-6">{{ form_row(form.telephone) }}</div>
	<div class="col-sm-12">{{ form_row(form.localisation) }}</div>
	<div class="col-sm-12">{{ form_row(form.nomResponsable) }}</div>
	<div class="col-sm-12">{{ form_row(form.siteWeb) }}</div>
</div>

<h5>Services que vous souhaitez offrir (facultatif).</h5>
{{ form_row(form.services) }}

<h5>Périmètre (Dans quelles villes)</h5>
{{ form_row(form.villes) }}

<div class="mt-3">
	<button class="site-button button" type="submit">
		<span class="btnFetch d-block w-100">
			{{ button_label|default('Terminer') }}
			<i class="fa fa-arrow-right"></i>
	  </span>
	</button>
</div>

{{ form_end(form, {render_rest: false}) }}