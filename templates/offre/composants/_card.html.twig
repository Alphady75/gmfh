<div class="twm-jobs-grid-style1">
   <div class="twm-media">
      <img src="{% if offre.user.logo %}{{ vich_uploader_asset(offre.user, 'logoFile' ) | imagine_filter('largeavatar') }}{% else %}{{ asset('img/banner.png') | imagine_filter('largeavatar') }}{% endif %}" alt="{{ offre }}">
   </div>
   <span class="twm-job-post-duration">{{ offre.created|ago }}</span>
   <div class="twm-jobs-category green">
      <span class="twm-bg-sky">{{ offre.lieuTravail|u.truncate(15, '...') }}</span>
   </div>
   <div class="twm-mid-content">
      <a href="{{ path('offre_details', {slug: offre.slug}) }}" class="twm-job-title">
         <h4 class="twm-job-title">{{ offre }}</h4>
      </a>
      <p class="twm-job-address">{{ offre.localisation }}</p>
      <a href="{{ offre.user.siteWeb ?? '#' }}"
         class="twm-job-websites site-text-primary">{{ offre.user.siteWeb }}</a>
   </div>
   <div class="twm-right-content">

      <div class="twm-jobs-amount">{{ offre.salaire }} {{ offre.devise }}
         <span>/ {{ offre.periodicite }}</span>
      </div>
      <a href="{{ path('offre_details', {slug: offre.slug}) }}" class="twm-jobs-browse site-text-primary">Parcourir l'offre</a>
   </div>
</div>