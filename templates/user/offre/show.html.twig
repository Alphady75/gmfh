{% extends 'espace.html.twig' %}

{% block title %}Offre{% endblock %}

{% block body %}
    <h1>Offre</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ offre.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ offre.name }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ offre.slug }}</td>
            </tr>
            <tr>
                <th>TypePost</th>
                <td>{{ offre.typePost }}</td>
            </tr>
            <tr>
                <th>TypeContrat</th>
                <td>{{ offre.typeContrat }}</td>
            </tr>
            <tr>
                <th>IntitulePost</th>
                <td>{{ offre.intitulePost }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ offre.description }}</td>
            </tr>
            <tr>
                <th>Localisation</th>
                <td>{{ offre.localisation }}</td>
            </tr>
            <tr>
                <th>DateDebut</th>
                <td>{{ offre.dateDebut ? offre.dateDebut|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>InfosContrat</th>
                <td>{{ offre.infosContrat }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('user_offre') }}">back to list</a>

    <a href="{{ path('user_offre_edit', {'id': offre.id}) }}">edit</a>

    {{ include('user/offre/_delete_form.html.twig') }}
{% endblock %}
