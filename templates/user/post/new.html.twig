	// Sélection du bouton
	let bouton = document.getElementById("add_image_button");

	// Initialisation du compteur de clics
	let compteurClics = 0;

	// Fonction pour masquer le bouton après trois clics
	function masquerApresTroisClics() {
		compteurClics++;
		if (compteurClics === 3) {
			bouton.style.display = "none";
		}
	}

	// Ajout d'un écouteur d'événements pour le clic sur le bouton
	bouton.addEventListener("click", masquerApresTroisClics);
	
