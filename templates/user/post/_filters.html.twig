{{ form_start(form, {attr: {class: 'filter-form'}}) }}
<div class="row d-flex align-items-baseline mb-0">
   <div class="row">
      <div class="col-sm-10">
         <div class="row mb-0">
            <div class="col-sm-5">{{ form_row(form.query) }}</div>
            <div class="col-sm-5">{{ form_row(form.souscategorie) }}</div>
            <div class="col-sm-2">{{ form_row(form.etat) }}</div>
         </div>
         <h4 class="mb-2">Conditions</h4>
         <div class="d-flex">
            <div class="me-3">{{ form_row(form.promo) }}</div>
            <div class="me-3">{{ form_row(form.negociable) }}</div>
            <div class="me-3">{{ form_row(form.livraison) }}</div>
         </div>
         {{ form_rest(form) }}
      </div>
      <div class="col-sm-2 ms-auto text-end">
         <button class="btn btn-outline-dark ms-auto radius">
            <i class="fa fa-filter"></i>
            Filtrer</button>
      </div>
   </div>
</div>
{{ form_end(form) }}