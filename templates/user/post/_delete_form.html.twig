<form method="post" class="d-inline" action="{{ path('user_post_delete', {'id': post.id}) }}" onsubmit="return confirm('Êtes-vous sûr de bien vouloir supprimer cet élément?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
    <button class="site-button bg-danger">Supprimer</button>
</form>
