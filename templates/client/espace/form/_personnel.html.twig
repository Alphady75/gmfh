{{ form_start(form, {attr: {class: 'p-4'}}) }}

<div class="mb-4">
	<label for="profil_personnel_photoFile_file" class="avatar-img">
		<img
			src="{% if app.user.photo %}{{ vich_uploader_asset(app.user, 'photoFile' )  }}{% else %}{{ asset('img/avatar.jpg')  }}{% endif %}"
			class="rounded-circle photo img-fluid" alt="Avatar de compte">
		<button class="btn" type="button"><i class="text-blue fa fa-camera"></i></button>
	</label>

	<div class="hidden-file">{{ form_widget(form.photoFile) }}</div>
	{{ form_errors(form.photoFile) }}
</div>

<h5 class="mb-4"><i class="text-blue fa fa-user-circle"></i> Informations individuelles</h5>

<div class="row">
	<div class="col-sm-6">{{ form_row(form.nom) }}</div>
	<div class="col-sm-6">{{ form_row(form.prenom) }}</div>
	<div class="col-sm-6">{{ form_row(form.localisation) }}</div>
	<div class="col-sm-6">{{ form_row(form.telephone) }}</div>
</div>

<div>
	<button class="site-button" type="submit">{{ button_label|default('Enregistrer') }}</button>
</div>

{{ form_end(form, {render_rest: false}) }}